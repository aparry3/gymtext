# =============================================================================
# WEB APP ENVIRONMENT VARIABLES (EXAMPLE)
# =============================================================================
# Copy to .env.local and fill in values

# PostHog Analytics (EU Cloud)
# Sign up at https://eu.posthog.com and create a project
# Host uses external reverse proxy at t.gymtext.co for ad-blocker bypass
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://t.gymtext.co

# Database
DATABASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# AI
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Session
SESSION_ENCRYPTION_KEY=

# URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SHORT_LINK_DOMAIN=http://localhost:3000

# Messaging
MESSAGING_PROVIDER=local
