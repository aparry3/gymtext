{
  "name": "gymtext-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:admin": "turbo dev --filter=admin",
    "check-env": "tsx scripts/check-env.ts",
    "check-env:ci": "tsx scripts/check-env.ts --ci",
    "migrate": "tsx scripts/migrations/run.ts latest",
    "build": "turbo build",
    "build:web": "turbo build --filter=web",
    "build:admin": "turbo build --filter=admin",
    "lint": "turbo lint",
    "inngest": "npx inngest-cli@latest dev",
    "db:codegen": "pnpm --filter @gymtext/shared db:codegen",
    "import:drills": "tsx scripts/import-drills.ts",
    "db:migrate": "tsx scripts/migrations/run.ts latest",
    "db:migrate:down": "tsx scripts/migrations/run.ts down",
    "db:migrate:create": "tsx scripts/migrations/create.ts",
    "migrate:create": "tsx scripts/migrations/create.ts",
    "seed": "tsx scripts/seed/index.ts",
    "signup": "tsx scripts/test-users/create-test-user.ts",
    "test:create-user": "tsx scripts/test-users/create-test-user.ts",
    "test:cleanup-users": "tsx scripts/test-users/cleanup-test-users.ts",
    "seed:help": "tsx scripts/seed/index.ts --help",
    "migrate:up": "tsx scripts/migrations/run.ts up",
    "migrate:latest": "tsx scripts/migrations/run.ts latest",
    "migrate:down": "tsx scripts/migrations/run.ts down",
    "db:dump": "tsx scripts/db/dump-data.ts",
    "db:restore": "tsx scripts/db/restore-data.ts",
    "db:reset-migrations": "tsx scripts/db/reset-migration-history.ts",
    "db:anonymize": "source .env.local && tsx scripts/db/anonymize.ts",
    "db:anonymize:staging": "source .env.staging && tsx scripts/db/anonymize.ts",
    "db:anonymize:dry": "source .env.local && tsx scripts/db/anonymize.ts --dry-run",
    "db:anonymize:dump": "source .env.local && tsx scripts/db/create-anonymized-dump.ts",
    "db:restore:staging": "source .env.staging && tsx scripts/db/restore-anonymized.ts",
    "test:migration": "source .env.local && tsx scripts/db/reset-from-main.ts",
    "sms:test": "source .env.local && tsx scripts/sms-test.ts",
    "local:sms": "node tools/local-sms-cli/dist/index.js",
    "local:sms:build": "cd tools/local-sms-cli && pnpm exec tsc",
    "clean": "bash scripts/clean.sh",
    "fresh": "bash scripts/clean.sh && pnpm install",
    "favicon:generate": "node scripts/generate-favicons.js",
    "backup:local": "source .env.local && ./scripts/backup-db.sh",
    "backup:prod": "source .env.production && ./scripts/backup-db.sh",
    "migrate:training": "tsx scripts/migrations/regenerate-training-data.ts",
    "migrate:regenerate": "tsx scripts/migrations/regenerate-for-new-schema.ts",
    "migrate:prompts": "tsx scripts/update-agent-prompts.ts",
    "agent:upsert": "source .env.local && tsx scripts/agent-definition.ts upsert",
    "agent:get": "source .env.local && tsx scripts/agent-definition.ts get",
    "agent:list": "source .env.local && tsx scripts/agent-definition.ts list",
    "agent:update-prompts": "source .env.local && tsx scripts/update-agent-prompts.ts",
    "agent:update-user-prompts": "source .env.local && tsx scripts/update-user-prompts.ts",
    "agent:update-user-prompts:dry": "source .env.local && tsx scripts/update-user-prompts.ts --dry-run",
    "fixture:capture": "source .env.local && tsx scripts/fixtures/capture.ts",
    "fixture:run": "source .env.local && tsx scripts/fixtures/run.ts",
    "calendly:webhooks": "source .env.local && tsx scripts/calendly/webhooks.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.5",
    "@dqbd/tiktoken": "^1.0.21",
    "@google/genai": "^1.31.0",
    "@hookform/resolvers": "^3.3.4",
    "@langchain/core": "^1.1.42",
    "@langchain/google-genai": "^0.2.4",
    "@langchain/openai": "^0.6.13",
    "@pinecone-database/pinecone": "^5.1.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "@types/luxon": "^3.7.0",
    "@types/uuid": "^10.0.0",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.3.1",
    "inngest": "^3.44.2",
    "kysely": "^0.28.16",
    "langchain": "^0.3.37",
    "lucide-react": "^0.331.0",
    "luxon": "^3.7.1",
    "next": "^16.2.4",
    "openai": "^4.104.0",
    "pg": "^8.14.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.50.0",
    "react-markdown": "^10.1.0",
    "redis": "^5.6.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^14.25.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.13.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.25.67",
      "brace-expansion@<1.1.12": ">=1.1.12",
      "brace-expansion@>=2.0.0 <2.0.2": ">=2.0.2",
      "flatted@<3.4.2": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "protobufjs@<7.5.5": ">=7.5.6",
      "mdast-util-to-hast@<13.2.1": ">=13.2.1",
      "follow-redirects@<1.16.0": ">=1.16.0",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0 <8.18.0": ">=8.18.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "google-auth-library@<10.6.2": ">=10.6.2",
      "postcss@<8.5.10": ">=8.5.12",
      "langsmith@<0.5.19": ">=0.5.19",
      "uuid@<14.0.0": ">=14.0.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^9.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20",
    "@types/pg": "^8.10.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/table": "^6.3.2",
    "autoprefixer": "^10.4.17",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.2.4",
    "inquirer": "^12.9.2",
    "kysely-codegen": "^0.20.0",
    "postcss": "^8.5.12",
    "sharp": "^0.34.3",
    "table": "^6.9.0",
    "tailwindcss": "^4",
    "tsx": "^4.7.1",
    "turbo": "^2.3.3",
    "typescript": "^5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0"
}
